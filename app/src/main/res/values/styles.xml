<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 상세 화면 섹션 제목 (액센트 색, 굵게) -->
    <style name="SecTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 상세 화면 섹션 본문 (박스 배경 + 흰 글씨) -->
    <style name="SecBody">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/section_bg</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- ▼ 레시피 게시판용 스타일 (신규 추가) -->

    <!-- 작성 화면의 한 줄 입력칸 (라면 이름/제목/작성자) -->
    <style name="InputBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:background">@drawable/section_bg</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textColorHint">@color/text_gray</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- 작성 화면의 여러 줄 입력칸 (재료/끓이는 법/팁). InputBox 를 상속받아 줄 수만 늘림 -->
    <style name="InputBoxMulti" parent="InputBox">
        <item name="android:inputType">textMultiLine</item>
        <item name="android:minLines">2</item>
        <item name="android:maxLines">6</item>
        <item name="android:gravity">top</item>
    </style>

    <!-- 인기 검색어 칩: 작고 흰 배경 + 회색 테두리, 글씨만 주황 (주황 면적 축소용)
         Material 테마에서 Button 은 주황 배경으로 덮여 흰 배경이 안 먹으므로 TextView 로 만든다. -->
    <style name="KwChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/chip_bg</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">7dp</item>
    </style>

    <!-- (구) 게시판 화면의 인기 검색어 버튼 (알약 배경 + 왼쪽 정렬 텍스트) — KwChip 으로 대체됨, 미사용 -->
    <style name="KwBtn">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:background">@drawable/pill_bg</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingHorizontal">18dp</item>
    </style>
</resources>