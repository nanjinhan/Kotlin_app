<?xml version="1.0" encoding="utf-8"?>
<!-- 카드 디자인 원칙 적용:
     · cardElevation=0 + 얇은 테두리(strokeWidth)로 'UI에는 그림자 안 쓴다' 원칙 구현
     · 카드 전체(cardRoot)에 클릭을 걸어 어디를 눌러도 상세로 이동 (터치 영역 = 시각 영역 일치) -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/hairline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_md">

        <!-- 표지 '받침대' 효과: 표지에만 그림자(cardElevation) 1개를 줘 책이 놓인 듯한 입체감.
             표지=제품 이미지이므로 그림자를 허용 (UI 카드와 구분) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="60dp"
            android:layout_height="86dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="@color/white">

            <!-- 표지 본체: 코드에서 책마다 다른 색을 칠하고 제목을 얹음 (이미지 파일 없이 표지 표현) -->
            <TextView
                android:id="@+id/tvCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="6dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:orientation="vertical">

            <!-- 제목: 위계 1순위. 크고 굵게, 글자 살짝 좁힘 -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 저자: 위계 3순위. 회색·작게 -->
            <TextView
                android:id="@+id/tvAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />

            <!-- 가격: 위계 2순위. 딥그린으로 강조 (단일 액센트로 중요한 정보만 칠함) -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/deep_green"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>