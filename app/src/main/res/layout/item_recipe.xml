<?xml version="1.0" encoding="utf-8"?>
<!--
  item_recipe.xml — 레시피 게시판의 카드 1개 모양.
  RecipeAdapter 가 이 레이아웃을 데이터 개수만큼 찍어내어 목록을 구성한다.
  구성: [썸네일 64dp] + [제목 / #라면이름 / by 작성자]
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/hairline"
    app:strokeWidth="1dp">

    <!-- 카드 안 내용: 가로 배치(썸네일 | 글자묶음) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/space_md">

        <!-- 썸네일: 이미지가 없으면 코드에서 연한 주황 배경으로 채움 -->
        <ImageView
            android:id="@+id/ivThumb"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop" />

        <!-- 오른쪽 글자 묶음: 제목 / 라면이름 / 작성자 세로로 쌓기 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/space_md">

            <!-- 제목(굵게, 한 줄 넘으면 ... 처리) -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- #라면이름 (액센트 색) -->
            <TextView
                android:id="@+id/tvRamen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/accent"
                android:textSize="13sp" />

            <!-- by 작성자 (회색) -->
            <TextView
                android:id="@+id/tvAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>